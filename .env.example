# ─── Database ────────────────────────────────────────────────────────────────
# Local dev:  file:./dev.db
# Production: postgres://user:pass@host:5432/stamped  (Render auto-fills this)
DATABASE_URL="file:./dev.db"

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me"

# ─── Anthropic (Claude) ──────────────────────────────────────────────────────
# ROTATE THIS KEY — it was exposed in chat. Get a new one at console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Microsoft Azure AD (SSO + Email) ────────────────────────────────────────
# ONE app registration handles both SSO login AND email sending.
#
# Setup in Azure portal → Azure Active Directory → App registrations:
#   1. Create (or use existing) app registration
#   2. Add redirect URIs:
#        https://your-app.onrender.com/api/auth/callback/azure-ad
#        http://localhost:3000/api/auth/callback/azure-ad
#   3. API permissions → Add:
#        - openid, profile, email  (Delegated — for SSO login)
#        - Mail.Send               (Application — to send approval emails)
#        - Mail.ReadWrite          (Application — to poll for advisor replies)
#   4. Click "Grant admin consent" for your tenant
#   5. Set AZURE_AD_TENANT_ID to your ACTUAL tenant ID (not "common") so
#      email sending works. Find it: Azure AD → Overview → Tenant ID.
#
# If AZURE_AD_TENANT_ID is "common", SSO still works but email won't — email
# requires a real tenant ID for the client credentials flow.
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
# Use your school's specific tenant ID (UUID from Azure AD → Overview)
# SSO can still accept users from any tenant; this just identifies YOUR org for email
AZURE_AD_TENANT_ID="your-tenant-id-here"
# Set to "true" to show the Microsoft SSO button on the login page
NEXT_PUBLIC_AZURE_AD_ENABLED="false"

# ─── Email Sending ───────────────────────────────────────────────────────────
# Option A: SMTP (easiest — no admin consent needed, works with any email)
#
#   Gmail:
#     SMTP_HOST=smtp.gmail.com  SMTP_PORT=587
#     SMTP_USER=you@gmail.com   SMTP_PASS=xxxx xxxx xxxx xxxx   ← App Password
#     Generate App Password: myaccount.google.com → Security → App passwords
#     (Must have 2-Step Verification enabled first)
#
#   Outlook.com personal account:
#     SMTP_HOST=smtp-mail.outlook.com  SMTP_PORT=587
#     SMTP_USER=you@outlook.com        SMTP_PASS=your-password
#
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""         # Optional: display name + address, e.g. "Purchasing <you@gmail.com>"
SMTP_FROM_NAME=""    # Optional: just the display name, e.g. "ERPL Purchasing"

# Option B: Microsoft Graph (requires IT admin consent from the mailbox's tenant)
# If using the SAME app as SSO above, leave MS_TENANT_ID / MS_CLIENT_ID /
# MS_CLIENT_SECRET blank — they fall back to AZURE_AD_* automatically.
# Only set these if you want a SEPARATE dedicated app registration for email.
MS_TENANT_ID=""
MS_CLIENT_ID=""
MS_CLIENT_SECRET=""
# The shared mailbox that sends approval emails and receives advisor replies.
# Required for inbox polling (auto-processing advisor reply emails).
MS_EMAIL_ADDRESS=""

# ─── Platform Admin ──────────────────────────────────────────────────────────
# Hardcoded super-admin above all tenants. Accesses /platform to manage schools.
# Set a strong password. This account has no tenant and bypasses all tenant guards.
PLATFORM_ADMIN_EMAIL="admin@stamped.app"
PLATFORM_ADMIN_PASSWORD="change-me-in-render"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_NAME="Stamped"
