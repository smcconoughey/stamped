# ─── Database ────────────────────────────────────────────────────────────────
# Local dev:  file:./dev.db
# Production: postgres://user:pass@host:5432/stamped  (Render auto-fills this)
DATABASE_URL="file:./dev.db"

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me"

# ─── Anthropic (Claude) ──────────────────────────────────────────────────────
# ROTATE THIS KEY — it was exposed in chat. Get a new one at console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Microsoft Azure AD (SSO) ────────────────────────────────────────────────
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# Redirect URI to add: https://your-app.onrender.com/api/auth/callback/azure-ad
#                      http://localhost:3000/api/auth/callback/azure-ad (local)
#
# Required API permissions: openid, profile, email (delegated)
# Optional (for email sending later): Mail.Send (delegated)
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
# Use "common" for multi-tenant (any Microsoft account)
# Use your school's tenant ID to restrict to your institution only
AZURE_AD_TENANT_ID="common"
# Set to "true" to show the Microsoft SSO button on the login page
NEXT_PUBLIC_AZURE_AD_ENABLED="false"

# ─── Microsoft Graph (email sending — Phase 2) ───────────────────────────────
# These can be the same values as Azure AD above once Mail.Send permission is granted
MS_TENANT_ID=""
MS_CLIENT_ID=""
MS_CLIENT_SECRET=""
# The mailbox that sends approval emails to advisors
MS_EMAIL_ADDRESS="purchasing@university.edu"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_NAME="Stamped"
